{
  "name": "stockflow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "catalog:build-review": "node scripts/build-catalog-review.mjs",
    "catalog:review-gate": "node scripts/build-catalog-review.mjs --fail-on-pending true",
    "catalog:prepare-reset": "node scripts/prepare-catalog-reset.mjs",
    "catalog:reconcile-images": "node scripts/reconcile-sku-images.mjs",
    "catalog:validate": "node scripts/validate-catalog-final.mjs",
    "catalog:patch-names": "node scripts/patch-product-names.mjs",
    "catalog:run-reset-safe": "npm run catalog:validate -- --file ./artifacts/catalog-reset-ready.csv --photos ./client-assets/photos-sku && npm run catalog:reconcile-images -- --file ./artifacts/catalog-reset-ready.csv --photos ./client-assets/photos-sku --out ./artifacts/catalog-reset-ready.csv --report-base ./artifacts/catalog-reset-ready-reconcile && npm run upload:images -- --dir ./client-assets/photos-sku --bucket product-images --output ./images-manifest.json && npm run import:catalog -- --file ./artifacts/catalog-reset-ready.csv --mode dry-run --images-manifest ./images-manifest.json && npm run live:reset-catalog -- --mode apply --file ./artifacts/catalog-reset-ready.csv --photos ./client-assets/photos-sku --images-manifest ./images-manifest.json --backup-dir ./artifacts/backups --bucket product-images --confirm-reset true",
    "import:catalog": "node scripts/import-catalog.mjs",
    "upload:images": "node scripts/upload-product-images.mjs",
    "live:reset-catalog": "node scripts/reset-live-catalog.mjs",
    "live:verify-alignment": "node scripts/live-verify-alignment.mjs",
    "ops:prune-artifacts": "node scripts/prune-generated-artifacts.mjs",
    "roles:check": "node scripts/check-access-roles.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "autoprefixer": "^10.4.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "shadcn": "^3.8.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
